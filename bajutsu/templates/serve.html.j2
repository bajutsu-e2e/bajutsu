        <button class="zbtn" id="crawl-zoomin" title="zoom in">+</button>
        <button class="zbtn" id="crawl-realign" title="realign nodes">&#8634;</button>
      </span>
    </div>
    <!-- Crash/flow scenario links for a selected past run (BE-0180): each crawl writes one
         crashes/crash-NNN.yaml per replayable crash and one flows/flow-NNN.yaml per reachable screen,
         both directly runnable by `bajutsu run`. Links point into the existing /runs/<id>/ static mount. -->
    <div class="crawl-artifacts" id="crawl-artifacts" data-testid="crawl.artifacts" hidden></div>
    <div class="crawlgraph" id="crawl-graph"><div class="empty">Start a crawl to watch the screen map grow.</div></div>
