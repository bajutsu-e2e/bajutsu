<!-- ===== Projects (BE-0275): the hub's home — list, add, remove, and switch config bindings =====
     Promoted out of the BE-0225 modal into a top-level view: a project is the concept above a config,
     not an action on one. The header switcher stays for a quick switch; this page owns the lifecycle.
     Its JS ships as the serve.projects.mjs ES module; serve.core.mjs (loadProjects) fills the list. -->
<main id="view-projects" data-testid="view.projects" hidden>
  <div class="card statscard">
    <div class="yamlhead">
      <span class="ttl">Projects</span>
      <span class="muted" style="font-size:.8em">Each project is a named binding to a config source. Switch rebinds the active config so every tab runs against it; removing one keeps its run history.</span>
      <button class="refresh" id="projects-refresh" data-testid="projects.refresh" title="refresh">&#8635;</button>
    </div>
    <!-- Add a project (BE-0275 unit 2): a name + one config-source string — a Git spec, or a local
         path when the server allows the fs source (BE-0108) — the same source `bajutsu project add
         --config` takes. Re-adding an existing name rebinds it. -->
    <div class="gitsrc prj-add">
      <label class="gitsrclbl" for="projects-add-name">Add a project</label>
      <div class="gitsrcrow">
        <input type="text" id="projects-add-name" data-testid="projects.add-name" placeholder="project name">
        <input type="text" id="projects-add-source" data-testid="projects.add-source" placeholder="github:owner/repo[@ref][:path] or a local path">
        <button class="cfgbtn" id="projects-add-submit" data-testid="projects.add-submit">Add</button>
      </div>
      <!-- Optional credential for a private repo (BE-0224): stored write-once, shared, masked, never
           echoed back — the same store the config launcher's Git picker uses. Needed only to switch
           to a private-repo project later, not to register it. -->
      <input type="password" id="projects-add-cred" data-testid="projects.add-cred" placeholder="private-repo credential (optional)" autocomplete="off" spellcheck="false">
      <div class="gitsrchint">A Git spec fetches the repo subtree when you switch to the project; a local path is offered only when the server permits it. Re-adding an existing name rebinds its source. The credential is optional — only for a <b>private</b> repository, stored write-once and shown only masked.</div>
      <span class="status" id="projects-add-status" data-testid="projects.add-status"></span>
      <div class="gitsrcerr" id="projects-error" data-testid="projects.error" hidden></div>
    </div>
    <div class="statshost" id="projects-host" data-testid="projects.host"><div class="empty" data-testid="projects.empty">Loading projects…</div></div>
  </div>
</main>

<!-- ===== Trash (BE-0239): soft-deleted runs, restorable within the retention window; an admin can
     permanently delete one. Regular and crawl runs share the trash, so both appear here. ===== -->
<main id="view-trash" data-testid="view.trash" hidden>
  <div class="card statscard">
    <div class="yamlhead">
      <span class="ttl">Trash</span>
      <span class="muted" id="trash-note" data-testid="trash.note" style="font-size:.8em"></span>
      <button class="refresh" id="trash-refresh" data-testid="trash.refresh" title="refresh">&#8635;</button>
    </div>
    <ul class="history trashlist" id="trash-list" data-testid="trash.list"><li class="muted">Loading…</li></ul>
  </div>
</main>

<!-- ===== Open config: a local file browser (confined to --root) + a "from Git" source ===== -->
<div class="modal" id="fsmodal" data-testid="config.modal" hidden>
  <div class="fsbox">
    <div class="fshead"><span class="ttl">Open config</span><button class="fsclose" id="fsclose" data-testid="config.close">&#10005;</button></div>
    <!-- From Git (BE-0063): materialize a repo subtree at a ref and bind its config. -->
    <div class="gitsrc">
      <label class="gitsrclbl" for="gitspec">From a Git repository</label>
      <div class="gitsrcrow">
        <input type="text" id="gitspec" data-testid="config.git-spec" placeholder="github:owner/repo@ref:path/to/bajutsu.config.yaml">
        <button class="cfgbtn" id="gitload" data-testid="config.git-load">Load</button>
      </div>
      <div class="gitsrchint">A branch, tag, or commit SHA (default: the repo's default branch). The whole subtree is fetched, so the config's scenarios and build come along.</div>
      <!-- Credential for a private repo (BE-0224): optional; write-once via the SecretStore seam,
           masked only, never echoed back. A public repo needs none. -->
      <div class="gitcred">
        <label class="gitsrclbl" for="gitcred">Credential for a private repository <span class="gitcredstate" id="gitcredstate" data-testid="config.git-cred-state"></span></label>
        <div class="gitsrcrow">
          <input type="password" id="gitcred" data-testid="config.git-cred" placeholder="fine-grained PAT or App token" autocomplete="off" spellcheck="false">
          <button class="cfgbtn" id="gitcredsave" data-testid="config.git-cred-save">Save</button>
        </div>
        <div class="gitsrchint">Optional &mdash; only for a <b>private</b> repository. Prefer a <b>fine-grained</b> personal access token (or a GitHub App token) scoped to this repo with <b>Contents: read</b>, over a broad classic token. Stored write-once and masked; it is never shown again. Enter it here and click Load, or Save it on its own.</div>
      </div>
      <div class="gitsrcerr" id="gitsrcerr" data-testid="config.git-error" hidden></div>
    </div>
    <!-- Upload a bundle (BE-0073): a self-contained .zip becomes the active config the tabs run from. -->
    <div class="gitsrc">
      <label class="gitsrclbl">Upload a bundle (.zip)</label>
      <div class="drop" id="up-drop" data-testid="upload.drop">
        <input type="file" id="up-file" data-testid="upload.file" accept=".zip,application/zip" hidden>
        <button class="cfgbtn" id="up-pick" type="button" data-testid="upload.pick">Choose a .zip…</button>
        <div class="dropmsg">or drop a bundle here</div>
      </div>
      <div class="gitsrchint">A <code>.zip</code> of a <code>bajutsu.config.yaml</code>, its scenarios, and the built app binary the config's <code>appPath</code> names &mdash; the same tree a local checkout has, delivered as one file. It extracts into a sandbox on the server and becomes the active config the Replay / Record / Crawl tabs run from. The bundle carries <b>no secrets</b>: <code>${secrets.*}</code> resolve from the server's environment.</div>
      <div class="upmeta" id="up-meta" data-testid="upload.meta" hidden></div>
      <div class="gitsrcerr" id="up-error" data-testid="upload.error" hidden></div>
    </div>
    <!-- Compose from artifacts (BE-0268): upload config / scenarios / binary independently, then
         assemble a triple. Each part is content-addressed, so an unchanged part is skipped (no
         re-upload) and a new binary×scenario combination is a fresh triple over stored parts. -->
    <div class="gitsrc">
      <label class="gitsrclbl">Compose from artifacts</label>
      <div class="composezones">
        <div class="composezone drop" id="cmp-config-drop" data-testid="compose.config.drop">
          <div class="composelbl">Config <span class="composereq">required</span></div>
          <input type="file" id="cmp-config-file" data-testid="compose.config.file" accept=".yml,.yaml,application/x-yaml" hidden>
          <button class="cfgbtn" id="cmp-config-pick" type="button" data-testid="compose.config.pick">Choose&hellip;</button>
          <div class="composestate" id="cmp-config-state" data-testid="compose.config.state"></div>
        </div>
        <div class="composezone drop" id="cmp-scenarios-drop" data-testid="compose.scenarios.drop">
          <div class="composelbl">Scenarios <span class="composeopt">(.zip / .yaml)</span></div>
          <input type="file" id="cmp-scenarios-file" data-testid="compose.scenarios.file" accept=".zip,application/zip,.yml,.yaml,application/x-yaml,text/yaml" hidden>
          <button class="cfgbtn" id="cmp-scenarios-pick" type="button" data-testid="compose.scenarios.pick">Choose&hellip;</button>
          <div class="composestate" id="cmp-scenarios-state" data-testid="compose.scenarios.state"></div>
        </div>
        <div class="composezone drop" id="cmp-binary-drop" data-testid="compose.binary.drop">
          <div class="composelbl">Binary <span class="composeopt">(.app.zip / .ipa / .apk)</span></div>
          <input type="file" id="cmp-binary-file" data-testid="compose.binary.file" accept=".zip,.app,.ipa,.apk,application/zip,application/vnd.android.package-archive,application/octet-stream" hidden>
          <button class="cfgbtn" id="cmp-binary-pick" type="button" data-testid="compose.binary.pick">Choose&hellip;</button>
          <div class="composestate" id="cmp-binary-state" data-testid="compose.binary.state"></div>
        </div>
      </div>
      <button class="cfgbtn" id="cmp-run" type="button" data-testid="compose.load">Compose &amp; load</button>
      <div class="gitsrchint">Each part is stored by the sha256 of its bytes, so an <b>unchanged</b> part (same sha) is <b>not re-uploaded</b>. <b>Scenarios</b> is a <code>.zip</code> of the scenario tree or a single <code>.yaml</code>; <b>binary</b> is a zipped <code>.app</code>, an <code>.ipa</code>, or an <code>.apk</code>. <b>Compose &amp; load</b> assembles the selected parts into the active config the Replay / Record / Crawl tabs run from &mdash; the config names where scenarios and the binary land. Swap one part and compose again to run a new combination without re-uploading the rest. The parts carry <b>no secrets</b>: <code>${secrets.*}</code> resolve from the server's environment.</div>
      <div class="upmeta" id="cmp-meta" data-testid="compose.meta" hidden></div>
      <div class="gitsrcerr" id="cmp-error" data-testid="compose.error" hidden></div>
    </div>
    <!-- The file browser is a local affordance; a hosted deployment hides this whole block, since a
         remote user has no filesystem relationship to the host (BE-0108). -->
    <div id="fssrc" data-testid="config.fs-source">
      <div class="fsor">or browse the server</div>
      <div class="fspath" id="fspath" data-testid="config.path"></div>
      <ul class="fslist" id="fslist" data-testid="config.list"></ul>
      <div class="fshint">Pick a <code>.yml</code>/<code>.yaml</code> config file. Browsing is limited to the server's <code>--root</code>.</div>
    </div>
  </div>
</div>

<!-- ===== View config: the raw YAML the tabs run from, plus its Git provenance (BE-0063) ===== -->
<div class="modal" id="cfgviewmodal" data-testid="config.view-modal" hidden>
  <div class="fsbox cfgviewbox">
    <div class="fshead">
      <span class="ttl">Loaded config</span>
      <!-- Structured (collapsible key/value tree) vs the raw YAML the file holds. -->
      <div class="cfgviewtoggle" role="tablist">
        <button class="cfgtogbtn active" id="cfgview-structured" data-testid="config.view-structured">Structured</button>
        <button class="cfgtogbtn" id="cfgview-raw" data-testid="config.view-raw">Raw</button>
      </div>
      <button class="fsclose" id="cfgviewclose" data-testid="config.view-close">&#10005;</button>
    </div>
    <!-- Provenance: for a Git source, which commit this was materialized from; hidden for a local file. -->
    <div class="cfgprov" id="cfgprov" data-testid="config.view-provenance" hidden></div>
    <div class="cfgpath" id="cfgviewpath" data-testid="config.view-path"></div>
    <div class="cfgtree" id="cfgviewtree" data-testid="config.view-tree"></div>
    <pre class="cfgview" id="cfgviewbody" data-testid="config.view-content" hidden></pre>
    <div class="gitsrchint">The config is shown verbatim. <code>${secrets.*}</code> placeholders are not resolved (they resolve from the server's environment at run time), but a secret written <b>literally</b> into the file would be shown as-is &mdash; keep secrets in <code>${secrets.*}</code> refs, not in the file.</div>
  </div>
</div>

<!-- Read-only scenario viewer (BE-0273): what the selected Replay scenario contains, before Run.
     Mirrors the config viewer (BE-0187) — a raw-YAML ↔ structured-steps toggle, never editable. -->
<div class="modal" id="scnviewmodal" data-testid="replay.scenario-view-modal" hidden>
  <div class="fsbox cfgviewbox">
    <div class="fshead">
      <span class="ttl">Scenario</span>
      <!-- Structured (runner-parsed per-scenario steps) vs the raw YAML the file holds. -->
      <div class="cfgviewtoggle" role="tablist">
        <button class="cfgtogbtn active" id="scnview-structured" data-testid="replay.scenario-view-toggle-structured">Structured</button>
        <button class="cfgtogbtn" id="scnview-raw" data-testid="replay.scenario-view-toggle-raw">Raw</button>
      </div>
      <button class="fsclose" id="scnviewclose" data-testid="replay.scenario-view-close">&#10005;</button>
    </div>
    <div class="cfgpath" id="scnviewpath" data-testid="replay.scenario-view-path"></div>
    <div class="cfgtree scnview-steps" id="scnviewtree" data-testid="replay.scenario-view-structured"></div>
    <pre class="cfgview" id="scnviewbody" data-testid="replay.scenario-view-content" hidden></pre>
    <div class="gitsrchint">Read-only: this never edits the scenario. The raw YAML is byte-for-byte what runs; the structured view is the runner's own parse of it.</div>
  </div>
</div>

<!-- ===== Settings: AI provider + Claude API key (one panel) ===== -->
<div class="modal" id="settingsmodal" data-testid="settings.modal" hidden>
  <div class="fsbox">
    <div class="fshead"><span class="ttl">Settings</span><button class="fsclose" id="settingsclose" data-testid="settings.close">&#10005;</button></div>
    <!-- Two concerns, one modal: the AI provider an operator sets once per machine, and the scenario
         secrets that vary with the bound config. The tab bar (same .tabs/.tab idiom as the Replay view)
         shows one at a time; serve.core.mjs showSettingsTab() toggles the panels below. -->
    <div class="tabs" role="tablist" data-testid="settings.tabs">
      <button class="tab active" type="button" data-settab="ai" data-testid="settings.tab-ai">AI</button>
      <button class="tab" type="button" data-settab="secrets" data-testid="settings.tab-secrets">Secrets</button>
      <button class="tab" type="button" data-settab="server" data-testid="settings.tab-server">Server</button>
    </div>
    <div id="setpanel-ai" data-testid="settings.panel-ai">
    <div class="setsection">
      <div class="setlabel">AI provider</div>
      <select id="provider" data-testid="settings.provider" class="keyinput">
        <option value="" data-testid="settings.provider-placeholder" selected>Select an AI provider…</option>
        <option value="api-key">Anthropic API (uses ANTHROPIC_API_KEY)</option>
        <option value="bedrock">Amazon Bedrock (uses AWS credentials)</option>
        <option value="ant">Anthropic CLI (ant, OAuth sign-in)</option>
        <option value="claude-code">Claude Code CLI (claude, subscription)</option>
      </select>
      <div id="claudecodefields" data-testid="settings.claudecode-fields" hidden>
        <div class="fshint">Every AI path (<b>Record</b>, <b>Crawl</b>, and the <b>alert guard</b>) reaches Claude by shelling out to the <code>claude</code> CLI on your Claude Code Pro/Max/Console subscription, with full vision (screenshots read from disk). No API key is needed &mdash; sign in once with <code>claude setup-token</code> (or an interactive <code>claude</code> login) on the machine running <code>serve</code>. Any <code>ANTHROPIC_API_KEY</code> is ignored for this provider so billing stays on the subscription.</div>
        <div class="setlabel">Claude Code OAuth token</div>
        <div class="keycur" id="cctokcur"></div>
        <label class="keylabel" for="cctoken">New token</label>
        <div class="keyrow">
          <input type="password" id="cctoken" data-testid="settings.cctoken" class="keyinput" placeholder="sk-ant-oat01-…" autocomplete="off" spellcheck="false">
        </div>
        <div class="keyactions">
          <button class="keyclear" id="cctokclear" data-testid="settings.cctoken-clear">Clear</button>
        </div>
        <div class="fshint">Optional, for a <b>headless host</b> that can't run <code>claude setup-token</code>'s browser flow (CI, a container, a remote <code>serve</code>): mint the long-lived token elsewhere and paste it here. Write-once &mdash; set or replace it here; it is shown only masked and never displayed again, and materializes as <code>CLAUDE_CODE_OAUTH_TOKEN</code> for spawned jobs. Leave blank if you signed in interactively on this machine.</div>
      </div>
      <div id="antfields" hidden>
        <div class="fshint">Every AI path (<b>Record</b>, <b>Crawl</b>, and the <b>alert guard</b>) reaches Claude through the official Anthropic CLI (<code>ant</code>) on your Pro/Max/Console seat instead of an API key. No API key is needed &mdash; the CLI's bearer token authenticates every request, with full vision (screenshots) on every path. <code>ANTHROPIC_PROFILE</code> selects a named profile.</div>
        <div class="keyactions">
          <button class="cfgbtn" id="ant-login" data-testid="settings.ant-login" hidden>Sign in with SSO</button>
          <span class="keystatus" id="ant-login-status" data-testid="settings.ant-login-status"></span>
        </div>
        <div class="fshint">Opens a browser sign-in (OAuth/SSO against the Claude Console) on the machine running <code>serve</code>, so this works with a local <code>make serve</code>. You can also sign in from a terminal with <code>ant auth login</code>.</div>
      </div>
      <div id="bedrockfields" data-testid="settings.bedrock-fields" hidden>
        <label class="keylabel" for="bedrock-region">AWS region</label>
        <input type="text" id="bedrock-region" data-testid="settings.bedrock-region" class="keyinput" placeholder="us-east-1" autocomplete="off" spellcheck="false">
        <label class="keylabel" for="bedrock-model">Bedrock model id</label>
        <input type="text" id="bedrock-model" data-testid="settings.bedrock-model" class="keyinput" placeholder="global.anthropic.claude-opus-4-6-v1" autocomplete="off" spellcheck="false">
        <div class="fshint">Bedrock model ids carry a provider prefix (<code>global.anthropic.&hellip;</code>, or a regional <code>us.anthropic.&hellip;</code>) &mdash; unlike the bare Anthropic id. Authentication uses your standard AWS credentials (environment, shared profile, or an IAM role); set <code>AWS_*</code> / <code>AWS_REGION</code> in your shell or a <code>.env</code> before launching <code>serve</code> if you don't use a profile or role.</div>
      </div>
    </div>
    <div class="setsection" id="modelsection" data-testid="settings.model-section">
      <div class="setlabel">Model &amp; effort</div>
      <label class="keylabel" for="ai-model">Model</label>
      <input type="text" id="ai-model" data-testid="settings.model" class="keyinput" placeholder="claude-opus-4-8 (default) — leave blank" autocomplete="off" spellcheck="false">
      <label class="keylabel" for="ai-effort">Reasoning effort</label>
      <select id="ai-effort" data-testid="settings.effort" class="keyinput">
        <option value="">default</option>
        <option value="low">low</option>
        <option value="medium">medium</option>
        <option value="high">high</option>
        <option value="xhigh">xhigh</option>
        <option value="max">max</option>
      </select>
      <div class="fshint">Applies to the <b>Anthropic API</b>, <b>ant</b>, and <b>Claude Code</b> providers (Bedrock uses the prefixed id above). Reasoning effort (low&ndash;max) is honored by the <b>Claude Code</b> provider (<code>--effort</code>); blank leaves the model's default.</div>
      <label class="keylabel" for="ai-language">Output language</label>
      <select id="ai-language" data-testid="settings.language" class="keyinput">
        <option value="auto">auto (keep current behavior)</option>
        <option value="ja">日本語</option>
        <option value="en">English</option>
      </select>
      <div class="fshint">The language the AI writes its generated prose in for <b>record</b> (the <code>from:</code> provenance) and <b>crawl</b> (its streamed reasoning). <b>auto</b> keeps today's behavior &mdash; record follows the goal's language, crawl stays English. This never affects the deterministic <code>run</code> verdict, and it is separate from a target's device <code>locale</code>.</div>
    </div>
    <div class="setsection" id="apikeysection" data-testid="settings.apikey-section">
      <div class="setlabel">Claude API key</div>
      <div class="keycur" id="keycur"></div>
      <label class="keylabel" for="apikey">New key</label>
      <div class="keyrow">
        <input type="password" id="apikey" data-testid="settings.apikey" class="keyinput" placeholder="sk-ant-…" autocomplete="off" spellcheck="false">
      </div>
      <div class="keyactions">
        <button class="keyclear" id="keyclear" data-testid="settings.key-clear">Clear</button>
      </div>
      <div class="fshint">Write-once: set or replace the key here; it is shown only masked and never displayed again. Used by the <b>Anthropic API</b> provider (Amazon Bedrock uses AWS credentials instead). Only the AI paths need it: <b>Record</b>, <b>Crawl</b>, and Replay with <code>--alert-handling</code>.</div>
    </div>
    <div class="keyactions">
      <button class="cfgbtn keysave" id="settingssave" data-testid="settings.save">Save</button>
      <span class="keystatus" id="setstatus" data-testid="settings.status"></span>
    </div>
    </div><!-- /setpanel-ai -->
    <div id="setpanel-secrets" data-testid="settings.panel-secrets" hidden>
    <!-- Scenario secrets (BE-0274): the ${secrets.X} names the bound config declares, each a masked
         write-once field. Populated by serve.core.mjs loadScenarioSecrets(). On its own tab now, the
         section always shows; #scnsecrets-empty stands in when the bound config declares none. -->
    <div class="setsection" id="scnsecretsection" data-testid="settings.scnsecrets-section">
      <div class="setlabel">Scenario secrets</div>
      <div class="fshint">The secrets this config's scenarios declare (<code>${secrets.X}</code>, BE-0032). Set each one here instead of <code>export</code>ing it before launching <code>serve</code>. Write-once &mdash; stored masked and never shown again; a spawned <b>Replay</b> / <b>Record</b> / <b>Crawl</b> resolves <code>${secrets.X}</code> from it.</div>
      <div class="fshint" id="scnsecrets-empty" data-testid="settings.scnsecrets-empty" hidden>This config's scenarios declare no secrets. When a scenario references <code>${secrets.X}</code>, a masked field for each name appears here.</div>
      <div id="scnsecrets-list" data-testid="settings.scnsecrets-list"></div>
    </div>
    </div><!-- /setpanel-secrets -->
    <div id="setpanel-server" data-testid="settings.panel-server" hidden>
    <!-- Server tab (BE-0318): a read-only view of how the running server is configured — deployment
         mode, the bound config and its Git source, the backends this build can run, run storage /
         retention / concurrency, the running version, and whether the bundled iOS test runner is
         deployed. No inputs: populated by serve.core.mjs loadServerInfo() from GET /api/server, which
         withholds host paths on a hosted deployment (BE-0108). The iOS runner row is the sharpest
         value — its absence silently blocks every iOS Simulator run (BE-0290/BE-0292). -->
    <div class="setsection" id="serverinfosection" data-testid="settings.serverinfo-section">
      <div class="setlabel">Server</div>
      <div class="fshint">How this running server is configured. Read-only &mdash; these values come from the launch command and environment; restart <code>serve</code> to change them.</div>
      <div id="serverinfo-rows" data-testid="settings.serverinfo-rows"></div>
    </div>
    </div><!-- /setpanel-server -->
    <div class="fshint">Settings live in the running server's memory for this session only &mdash; <b>not written to disk</b>, so they reset when <code>serve</code> restarts. For values that survive restarts, set <code>ANTHROPIC_API_KEY</code> / <code>AWS_*</code> in your shell or a <code>.env</code> before launching <code>serve</code>.</div>
  </div>
</div>
<!-- ===== Theme editor: create/edit themes with live preview (BE-0191 unit 6) ===== -->
<div class="modal" id="thememodal" data-testid="theme.modal" hidden>
  <div class="fsbox">
    <div class="fshead"><span class="ttl">Theme Editor</span><button class="fsclose" id="themeclose" data-testid="theme.close">&#10005;</button></div>
    <div id="themecontent" data-testid="theme.content">
      <!-- Form populated by serve.core.mjs initThemeEditor(): a kind selector, a native color input
           per color token, and a text input per motion token (durations, easing, keyframe names). -->
    </div>
    <div class="keyactions">
      <button class="cfgbtn" id="themesave-local" data-testid="theme.save-local">Save to Local Draft</button>
      <button class="cfgbtn" id="themesave-upload" data-testid="theme.save-upload" hidden>Upload to Server</button>
      <button class="cfgbtn" id="themeexport" data-testid="theme.export">Export</button>
      <button class="cfgbtn" id="themeimport" data-testid="theme.import">Import</button>
      <input type="file" id="themeimport-input" accept=".css" hidden>
      <span class="keystatus" id="themestatus" data-testid="theme.status"></span>
    </div>
  </div>
</div>
<!-- ===== Screenshot lightbox: the enlarged screen + where it goes next (Crawl tab) ===== -->
<div class="modal" id="shotmodal" hidden>
  <div class="shotbox">
    <button class="fsclose shotclose" id="shotclose">&#10005;</button>
    <button class="shotnav prev" id="shotprev" title="previous screen — a transition into this one (←)">&#8249;</button>
    <div class="shotmain"><div class="shotframe"><img id="shotimg" alt="screen screenshot"><div class="shothots" id="shothots"></div><div class="shothi" id="shothi" hidden></div></div></div>
    <button class="shotnav fwd" id="shotfwd" title="next screen — a transition out of this one (→)">&#8250;</button>
    <div class="shotside">
      <div class="shottitle" id="shottitle"></div>
      <div class="shotnext" id="shotnext"></div>
    </div>
  </div>
</div>
<script type="module" src="/{{ js_entry }}"></script>
</body></html>
