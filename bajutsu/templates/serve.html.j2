{#- The serve WebUI shell. Markup lives here; CSS/JS are inlined (passed in as
    `themes_css` / `css` / `js`). Keep this in sync with serve.css / serve.js. -#}
<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1">
<title>bajutsu</title>
{#- Resolve the theme before first paint so there is no dark→light flash on load. -#}
<script>(function(){try{var t=localStorage.getItem('bajutsu-theme');if(!t)t=matchMedia('(prefers-color-scheme: light)').matches?'daylight':'midnight';document.documentElement.setAttribute('data-theme',t)}catch(e){}})();</script>
<style>{{ themes_css|safe }}{{ css|safe }}</style></head>
<body>
<header>
  <div class="brandcol">
    <span class="brand">bajutsu</span>
    <div class="toptabs">
      <button class="toptab active" data-view="record" data-testid="nav.record">Record</button>
      <button class="toptab" data-view="replay" data-testid="nav.replay">Replay</button>
      <button class="toptab" data-view="crawl" data-testid="nav.crawl">Crawl</button>
      <button class="toptab" data-view="author" data-testid="nav.author">Author</button>
      <button class="toptab" data-view="stats" data-testid="nav.stats">Stats</button>
      <button class="cfgbtn" id="opencfg" data-testid="nav.open-config">Open config</button>
      <span class="cfgname" id="cfgname" data-testid="nav.config-name"></span>
      <button class="cfgbtn" id="opensettings" data-testid="nav.settings">Settings</button>
    </div>
  </div>
  <label class="themeswitch" title="dark / light mode (follows your system by default)">
    <svg class="ico moon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
    <input type="checkbox" id="theme" data-testid="nav.theme-toggle" aria-label="toggle dark / light mode">
    <span class="track"><span class="thumb"></span></span>
    <svg class="ico sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"/></svg>
  </label>
</header>

<!-- ===== Record: author a scenario from a natural-language goal ===== -->
<main id="view-record" data-testid="view.record" data-pane="form">
  <!-- Per-view switcher (shown only at the phone tier): brings one stacked pane to full width. -->
  <div class="viewswitch" role="tablist" data-testid="record.switch">
    <button class="vstab active" data-pane="form">Form</button>
    <button class="vstab" data-pane="log">Progress</button>
    <button class="vstab" data-pane="yaml">Output</button>
  </div>
  <div class="left" data-pane="form">
    <!-- Claude-reachability gate (BE-0101): shown disabled with an inline explanation when Claude is
         unreachable, so `record` degrades gracefully instead of failing only on click. Lives inside
         the controls pane so the desktop tile layout (which replaces the view's direct children)
         keeps it. -->
    <div class="ai-gate" id="rec-aigate" data-testid="record.ai-gate" hidden></div>
    <div class="card">
      <div class="panel" id="panel-record">
        <label>Goal (natural language)</label>
        <textarea id="rec-goal" data-testid="record.goal" class="goal" placeholder="e.g. increment the counter twice and check it reads 2"></textarea>
        <label>Target</label><select id="rec-target" data-testid="record.target"></select>
        <label class="iosonly">Device</label>
        <div class="row iosonly" style="align-items:flex-end">
          <div><select id="rec-device"></select></div>
          <div style="flex:0 0 auto"><button class="refresh" id="rec-simrefresh" title="refresh devices">&#8635;</button></div>
        </div>
        <label>Save as</label>
        <input id="rec-name" type="text" placeholder="generated.yaml — leave blank to default">
        <div class="subhint">The recorded scenario is written under the scenarios dir, so it shows up in the <b>Replay</b> tab to run. Blank defaults to <code>generated.yaml</code>; if the name already exists, the run's date-time is appended (e.g. <code>generated-20260613-153045.yaml</code>) so nothing is overwritten.</div>
        <div class="checks iosonly">
          <label><input type="checkbox" id="rec-erase"> erase device first
            <span class="hint">Wipe the simulator before authoring (record's default) so the app starts from onboarding. Uncheck to author against the app's current state.</span></label>
          <label><input type="checkbox" id="rec-nodismiss"> disable alert-dismiss
            <span class="hint">The alert guard (Claude vision) dismisses unexpected system prompts while authoring; on by default (needs ANTHROPIC_API_KEY). Check to force it off.</span></label>
        </div>
        <div class="checks webonly">
          <label><input type="checkbox" id="rec-headed" data-testid="record.headed"> show browser (headed)
            <span class="hint">Author against a visible Chromium window in slow-motion so you can watch the agent explore, instead of the default headless browser. The window opens on the machine running <code>serve</code>.</span></label>
        </div>
      </div>
    </div>
  </div>
  <div class="gutter" data-var="--rec-left" data-min="260" data-max="640"></div>
  <div class="rec-stack">
    <div class="card logpanel" data-pane="log">
      <button class="run" id="rec-go" data-testid="record.generate" data-idle="Generate scenario">Generate scenario</button>
      <button class="stop" id="rec-stop" hidden>Stop</button>
      <div class="status" id="rec-status"></div>
      <pre class="out" id="rec-out" data-empty="Enter a goal and press Generate to watch the agent author it, turn by turn."></pre>
    </div>
    <div class="gutter row" data-var="--rec-top" data-min="120" data-max="700"></div>
    <div class="card yamlpanel" id="rec-yamlpanel" data-pane="yaml">
      <div class="yamlhead">
        <span class="ttl">Generated scenario</span>
        <span class="muted" id="rec-yamlinfo" style="font-size:.8em"></span>
        <button class="savebtn" id="rec-save" data-testid="record.save" disabled>Save</button>
      </div>
      <textarea id="rec-yaml" data-testid="record.yaml" class="yaml" placeholder="The recorded scenario YAML appears here once authoring finishes — edit and Save, then run it in the Replay tab."></textarea>
    </div>
  </div>
</main>

<!-- ===== Replay: run a scenario and view its report ===== -->
<main id="view-replay" data-testid="view.replay" data-pane="form" hidden>
  <div class="viewswitch" role="tablist" data-testid="replay.switch">
    <button class="vstab active" data-pane="form">Form</button>
    <button class="vstab" data-pane="log">Log</button>
    <button class="vstab" data-pane="report">Report</button>
  </div>
  <div class="left" data-pane="form">
    <div class="card">
      <div class="tabs">
        <button class="tab active" data-tab="run" data-testid="replay.tab-run">Run</button>
        <button class="tab" data-tab="history" id="histtab" data-testid="replay.tab-history">History</button>
      </div>
      <div class="panel" id="panel-run" data-testid="replay.panel-run">
        <label>Scenario</label>
        <select id="scn" data-testid="replay.scenario"></select><div class="names" id="names" data-testid="replay.scenario-info"></div>
        <label>Target</label><select id="target" data-testid="replay.target"></select>
        <div class="row iosonly"><div><label>Workers</label><input id="workers" type="number" min="1" value="1"></div></div>
        <div class="hhead iosonly" data-testid="replay.simulators"><span>Simulators</span><button class="refresh" id="simrefresh" title="refresh devices">&#8635;</button></div>
        <div class="sims iosonly" id="sims"></div>
        <div class="subhint iosonly">Pick the simulators to run on &mdash; shut-down ones are booted (and waited for) before the run. Pick two or more (Workers auto-tracks the count) to run the scenarios in parallel across them: each device gets its own network capture, video / device log, and setLocation / push. None picked = the already-booted device.</div>
        <div class="checks iosonly">
          <label><input type="checkbox" id="erasedev"> erase device first
            <span class="hint">Wipe the whole simulator (simctl erase &mdash; all apps, data, settings) before each scenario. Off (default) leaves it to each scenario's <code>preconditions.erase</code>; the app is reinstalled fresh either way.</span></label>
          <label><input type="checkbox" id="nodismiss"> disable alert-dismiss
            <span class="hint">The alert guard is on by default: Claude vision dismisses unexpected system prompts (Save Password, notification permission) that idb can't see or tap (needs ANTHROPIC_API_KEY). Check to force it off for this run; a scenario can also set <code>dismissAlerts</code> itself.</span></label>
        </div>
        <div class="checks webonly">
          <label><input type="checkbox" id="headed" data-testid="replay.headed"> show browser (headed)
            <span class="hint">Run in a visible Chromium window in slow-motion so you can watch each step, instead of the default headless browser. The window opens on the machine running <code>serve</code> (so this is for a local server).</span></label>
        </div>
      </div>
      <div class="panel" id="panel-history" data-testid="replay.panel-history" hidden>
        <div class="hhead"><span>Past runs</span><button class="refresh" id="refresh" title="refresh">&#8635;</button></div>
        <ul class="history" id="history"></ul>
      </div>
    </div>
  </div>
  <div class="gutter" data-var="--rep-left" data-min="260" data-max="560"></div>
  <div class="card logpanel" data-pane="log">
    <button class="run" id="go" data-testid="replay.run" data-idle="Run">Run</button>
    <button class="stop" id="stop" hidden>Stop</button>
    <div class="status" id="status"></div>
    <pre class="out" id="out" data-empty="Run a scenario to see its output here."></pre>
  </div>
  <div class="gutter" data-var="--rep-mid" data-min="220" data-max="640"></div>
  <div class="report" id="report" data-testid="replay.report" data-pane="report"><div class="empty">Run a scenario to see its report here.</div></div>
</main>

<!-- ===== Crawl: explore the app breadth-first and map its screens live ===== -->
<main id="view-crawl" data-testid="view.crawl" data-pane="form" hidden>
  <div class="viewswitch" role="tablist" data-testid="crawl.switch">
    <button class="vstab active" data-pane="form">Form</button>
    <button class="vstab" data-pane="graph">Graph</button>
    <button class="vstab" data-pane="plan">Plan</button>
    <button class="vstab" data-pane="console">Console</button>
  </div>
  <div class="left" data-pane="form">
    <!-- Claude-reachability gate (BE-0101); see the record view above. -->
    <div class="ai-gate" id="crawl-aigate" data-testid="crawl.ai-gate" hidden></div>
    <div class="card">
      <div class="panel" id="panel-crawl">
        <label>Target</label><select id="crawl-target" data-testid="crawl.target"></select>
        <div class="row" style="align-items:flex-end">
          <div><label>Workers</label><input id="crawl-workers" type="number" min="1" value="1"></div>
        </div>
        <div class="subhint webonly">Crawl this many browser processes at once, sharing one screen map (BE-0077): independent branches explore in parallel and the AI guide's round-trips overlap, so the map builds faster. Each worker is its own browser, so one that wedges is relaunched without sinking the crawl. 1 = a single browser.</div>
        <div class="hhead iosonly"><span>Simulators</span><button class="refresh" id="crawl-simrefresh" title="refresh devices">&#8635;</button></div>
        <div class="sims iosonly" id="crawl-sims"></div>
        <div class="subhint iosonly">Pick the simulators to crawl on &mdash; shut-down ones are booted (and waited for) first. Pick two or more (Workers auto-tracks the count) to crawl across them in parallel: they share one screen map, so independent branches explore at once and the AI guide's round-trips overlap (BE-0064). None picked = the already-booted device.</div>
        <div class="row">
          <div><label>Max screens</label><input id="crawl-maxscreens" type="number" min="1" value="50"></div>
          <div><label>Max steps</label><input id="crawl-maxsteps" type="number" min="1" value="200"></div>
        </div>
        <div class="subhint">Crawl explores the app breadth-first, discovering screens and the transitions between them &mdash; a discovery tool, never a pass/fail gate. It is AI-driven: the engine (screen identity, transitions, crashes) is always deterministic, while the <b>AI</b> proposes <i>what to try</i> &mdash; richer operations and realistic inputs to enable controls whose precondition isn't obvious. The AI backend is the one chosen in <b>Settings</b> &mdash; the Anthropic API, Amazon Bedrock, or the Claude Code CLI. Stops at the first of Max screens / Max steps.</div>
        <div class="checks iosonly">
          <label><input type="checkbox" id="crawl-erase"> erase device first
            <span class="hint">Wipe the simulator before crawling so the app starts from onboarding. Off by default — the app is reinstalled fresh either way; check to also wipe all apps / data / settings first.</span></label>
          <label><input type="checkbox" id="crawl-nodismiss"> disable alert-dismiss
            <span class="hint">The alert guard (Claude vision) dismisses unexpected OS prompts so they aren't read as crashes; on by default (uses the AI provider set in Settings &mdash; ANTHROPIC_API_KEY for Anthropic, or AWS credentials for Bedrock). Check to force it off.</span></label>
        </div>
        <div class="checks webonly">
          <label><input type="checkbox" id="crawl-headed" data-testid="crawl.headed"> show browser (headed)
            <span class="hint">Crawl a visible Chromium window in slow-motion so you can watch the exploration, instead of the default headless browser. The window opens on the machine running <code>serve</code>.</span></label>
        </div>
        <button class="run" id="crawl-go" data-testid="crawl.start" data-idle="Start crawl">Start crawl</button>
        <button class="stop" id="crawl-stop" hidden>Stop</button>
        <div class="status" id="crawl-status"></div>
      </div>
    </div>
  </div>
  <div class="card crawl-graph-panel" data-pane="graph">
    <div class="crawlhead">
      <span class="ttl">Screen map</span>
      <span class="crawlcounts" id="crawl-counts"></span>
      <span class="zoomctl">
        <button class="zbtn" id="crawl-zoomout" title="zoom out">&minus;</button>
        <button class="zbtn" id="crawl-zoomreset" title="reset view">&#9678;</button>
        <button class="zbtn" id="crawl-zoomin" title="zoom in">+</button>
      </span>
    </div>
    <div class="crawlgraph" id="crawl-graph"><div class="empty">Start a crawl to watch the screen map grow.</div></div>
  </div>
  <div class="card crawl-plan-panel" data-pane="plan">
    <div class="crawlsub planhd"><span>Exploration plan<span class="planpct" id="crawl-planpct"></span></span>
      <label class="prunetog" title="Show the operations the crawl pruned as duplicate global controls (a tab/nav explored once), struck through and tappable to resume. Uncheck to hide them."><input type="checkbox" id="crawl-prune" checked> show pruned</label></div>
    <div class="planbar" title="share of planned operations explored"><div class="planfill" id="crawl-planfill"></div></div>
    <div class="crawlplan" id="crawl-plan"><div class="empty">The plan tree grows as the crawl explores.</div></div>
  </div>
  <div class="card crawl-console-panel" data-pane="console">
    <div class="crawlsub">Console</div>
    <pre class="out crawllog" id="crawl-out" data-empty="Crawl progress appears here."></pre>
  </div>
</main>

<!-- ===== Author (BE-0098): one open scenario, three modes (Capture / Edit / Enrich) =====
     Unifies the former Capture (BE-0012) and Editor (BE-0013) tabs and the Enrich panel
     (BE-0014). The mode switcher below picks what a click on the shared screenshot does;
     switching mode never reloads the scenario or drops unsaved YAML edits. -->
<main id="view-author" data-testid="view.author" data-pane="form" hidden>
  <div class="viewswitch" role="tablist" data-testid="author.switch">
    <button class="vstab active" data-pane="form">Form</button>
    <button class="vstab" data-pane="screen">Screen</button>
    <button class="vstab" data-pane="steps">Steps</button>
  </div>

  <div class="left" data-pane="form">
    <!-- Mode switcher: a button row, not tabs — distinct from the top-level nav above. -->
    <div class="modeswitch" role="tablist" data-testid="author.mode">
      <button class="modetab active" data-mode="capture" data-testid="author.mode-capture">Capture</button>
      <button class="modetab" data-mode="edit" data-testid="author.mode-edit">Edit</button>
      <button class="modetab" data-mode="enrich" data-testid="author.mode-enrich">Enrich</button>
    </div>
    <div class="card">
      <div class="panel" id="panel-author">
        <label>Target</label><select id="au-target" data-testid="author.target"></select>
        <!-- Scenario + run selection: Edit / Enrich load an existing scenario; Capture starts fresh. -->
        <div class="au-loadrow">
          <label>Scenario</label><select id="au-scenario" data-testid="author.scenario"></select>
          <label>Run</label><select id="au-run" data-testid="author.run"></select>
          <button class="run" id="au-load" data-testid="author.load" data-idle="Load">Load</button>
        </div>
        <!-- Capture-only: what a screenshot click records. -->
        <div class="au-cap">
          <label>Action mode</label>
          <div class="checks">
            <label><input type="radio" name="au-mode" value="tap" checked> tap</label>
            <label><input type="radio" name="au-mode" value="type"> type</label>
          </div>
          <div id="au-type-field" hidden>
            <label>Text to type</label>
            <input id="au-text" type="text" placeholder="text to enter into the focused field">
          </div>
        </div>
      </div>
    </div>
    <div class="card au-steps-card" data-pane="steps">
      <div class="yamlhead"><span class="ttl">Steps</span><span class="muted" id="au-step-count">0 steps</span></div>
      <ol id="au-steplist" class="au-steplist"></ol>
    </div>
    <div class="card yamlpanel" id="au-yamlpanel" data-pane="yaml">
      <div class="yamlhead">
        <span class="ttl">Scenario YAML</span>
        <button class="savebtn au-enrich" id="au-enrich" data-testid="author.enrich" disabled>Enrich</button>
        <button class="savebtn" id="au-save" data-testid="author.save" disabled>Save</button>
      </div>
      <div class="yamledit">
        <div class="yamlgutter" id="au-gutter" aria-hidden="true"><div class="yamlgutter-inner" id="au-gutter-inner"></div></div>
        <textarea id="au-yaml" class="yaml" placeholder="Capture a flow or load a scenario to edit its YAML here." spellcheck="false"></textarea>
        <div class="yamlcomplete" id="au-complete" hidden></div>
        <div class="yamlhover" id="au-hover" hidden></div>
      </div>
      <div class="au-problems" id="au-problems" data-testid="author.problems" hidden></div>
      <div class="enrich-panel" id="au-enrich-panel" hidden>
        <div class="enrich-head">
          <span class="ttl">Proposed assertions</span>
          <span class="enrich-actions">
            <button class="savebtn enrich-accept" id="au-enrich-accept" data-testid="author.enrich-accept">Accept</button>
            <button class="savebtn enrich-dismiss" id="au-enrich-dismiss" data-testid="author.enrich-dismiss">Dismiss</button>
          </span>
        </div>
        <div class="enrich-note" id="au-enrich-note"></div>
        <ul class="enrich-list" id="au-enrich-list"></ul>
      </div>
    </div>
  </div>

  <div class="gutter" data-var="--rec-left" data-min="260" data-max="640"></div>

  <div class="rec-stack">
    <div class="card au-screen-card" data-pane="screen">
      <!-- Capture-only: start / finish a live session. -->
      <div class="au-cap au-btnrow">
        <button class="run" id="au-start" data-testid="author.start" data-idle="Start capture">Start capture</button>
        <button class="run" id="au-finish" data-testid="author.finish" hidden>Finish &amp; save</button>
      </div>
      <!-- Edit-only: step navigation across the loaded run's screenshots. -->
      <div class="au-step-nav au-edit">
        <button class="run au-nav-btn" id="au-prev" data-testid="author.prev" disabled>&larr; Prev</button>
        <span class="au-step-label" id="au-step-label">No step loaded</span>
        <button class="run au-nav-btn" id="au-next" data-testid="author.next" disabled>Next &rarr;</button>
      </div>
      <div class="status" id="au-status"></div>
      <div class="au-screen-wrap" id="au-screen-wrap">
        <div class="au-placeholder" id="au-placeholder">Pick a mode: Capture a new flow, or load a scenario to Edit / Enrich.</div>
        <img id="au-screenshot" class="au-screenshot" hidden alt="scenario screenshot">
        <div class="au-feedback" id="au-feedback" hidden>
          <span class="au-rung" id="au-rung"></span>
          <span id="au-sel"></span>
          <button class="savebtn au-edit" id="au-apply" data-testid="author.apply">Apply</button>
        </div>
      </div>
    </div>
  </div>
</main>

<!-- ===== Stats (BE-0102): the read-only aggregate run-stats dashboard across the run history ===== -->
<main id="view-stats" data-testid="view.stats" hidden>
  <div class="card statscard">
    <div class="yamlhead">
      <span class="ttl">Run stats</span>
      <span class="muted" style="font-size:.8em">Read-only trend across the run history — no verdict, advisory only.</span>
      <button class="refresh" id="stats-refresh" data-testid="stats.refresh" title="refresh">&#8635;</button>
    </div>
    <div class="statshost" id="stats-host" data-testid="stats.host"><div class="empty">Loading run stats…</div></div>
  </div>
</main>

<!-- ===== Open config: a local file browser (confined to --root) + a "from Git" source ===== -->
<div class="modal" id="fsmodal" data-testid="config.modal" hidden>
  <div class="fsbox">
    <div class="fshead"><span class="ttl">Open config</span><button class="fsclose" id="fsclose" data-testid="config.close">&#10005;</button></div>
    <!-- From Git (BE-0063): materialize a repo subtree at a ref and bind its config. -->
    <div class="gitsrc">
      <label class="gitsrclbl" for="gitspec">From a Git repository</label>
      <div class="gitsrcrow">
        <input type="text" id="gitspec" data-testid="config.git-spec" placeholder="github:owner/repo@ref:path/to/bajutsu.config.yaml">
        <button class="cfgbtn" id="gitload" data-testid="config.git-load">Load</button>
      </div>
      <div class="gitsrchint">A branch, tag, or commit SHA (default: the repo's default branch). The whole subtree is fetched, so the config's scenarios and build come along.</div>
      <div class="gitsrcerr" id="gitsrcerr" data-testid="config.git-error" hidden></div>
    </div>
    <!-- Upload a bundle (BE-0073): a self-contained .zip becomes the active config the tabs run from. -->
    <div class="gitsrc">
      <label class="gitsrclbl">Upload a bundle (.zip)</label>
      <div class="drop" id="up-drop" data-testid="upload.drop">
        <input type="file" id="up-file" data-testid="upload.file" accept=".zip,application/zip" hidden>
        <button class="cfgbtn" id="up-pick" type="button" data-testid="upload.pick">Choose a .zip…</button>
        <div class="dropmsg">or drop a bundle here</div>
      </div>
      <div class="gitsrchint">A <code>.zip</code> of a <code>bajutsu.config.yaml</code>, its scenarios, and the built app binary the config's <code>appPath</code> names &mdash; the same tree a local checkout has, delivered as one file. It extracts into a sandbox on the server and becomes the active config the Replay / Record / Crawl tabs run from. The bundle carries <b>no secrets</b>: <code>${secrets.*}</code> resolve from the server's environment.</div>
      <div class="upmeta" id="up-meta" data-testid="upload.meta" hidden></div>
      <div class="gitsrcerr" id="up-error" data-testid="upload.error" hidden></div>
    </div>
    <!-- The file browser is a local affordance; a hosted deployment hides this whole block, since a
         remote user has no filesystem relationship to the host (BE-0108). -->
    <div id="fssrc" data-testid="config.fs-source">
      <div class="fsor">or browse the server</div>
      <div class="fspath" id="fspath" data-testid="config.path"></div>
      <ul class="fslist" id="fslist" data-testid="config.list"></ul>
      <div class="fshint">Pick a <code>.yml</code>/<code>.yaml</code> config file. Browsing is limited to the server's <code>--root</code>.</div>
    </div>
  </div>
</div>

<!-- ===== Settings: AI provider + Claude API key (one panel) ===== -->
<div class="modal" id="settingsmodal" data-testid="settings.modal" hidden>
  <div class="fsbox">
    <div class="fshead"><span class="ttl">Settings</span><button class="fsclose" id="settingsclose" data-testid="settings.close">&#10005;</button></div>
    <div class="setsection">
      <div class="setlabel">AI provider</div>
      <select id="provider" data-testid="settings.provider" class="keyinput">
        <option value="" data-testid="settings.provider-placeholder" selected>Select an AI provider…</option>
        <option value="anthropic">Anthropic API (uses ANTHROPIC_API_KEY)</option>
        <option value="bedrock">Amazon Bedrock (uses AWS credentials)</option>
        <option value="claude-code">Claude Code (the claude CLI, your subscription)</option>
      </select>
      <div id="claudecodefields" hidden>
        <div class="fshint"><b>Record</b> and <b>Crawl</b> author through the local <code>claude</code> CLI (Claude Code) on your Pro/Max subscription instead of the pay-per-token API. Install Claude Code and authenticate it (<code>claude setup-token</code>) in the environment that launched <code>serve</code>; an <code>ANTHROPIC_API_KEY</code>, if set, is stripped from the call so the subscription is billed. Authoring is text-only (no screenshot). The <b>alert guard</b> (Replay / Crawl with dismiss-alerts) still uses the Anthropic SDK; set <code>ANTHROPIC_API_KEY</code> in the environment for it, otherwise it no-ops.</div>
      </div>
      <div id="bedrockfields" data-testid="settings.bedrock-fields" hidden>
        <label class="keylabel" for="bedrock-region">AWS region</label>
        <input type="text" id="bedrock-region" data-testid="settings.bedrock-region" class="keyinput" placeholder="us-east-1" autocomplete="off" spellcheck="false">
        <label class="keylabel" for="bedrock-model">Bedrock model id</label>
        <input type="text" id="bedrock-model" data-testid="settings.bedrock-model" class="keyinput" placeholder="global.anthropic.claude-opus-4-6-v1" autocomplete="off" spellcheck="false">
        <div class="fshint">Bedrock model ids carry a provider prefix (<code>global.anthropic.&hellip;</code>, or a regional <code>us.anthropic.&hellip;</code>) &mdash; unlike the bare Anthropic id. Authentication uses your standard AWS credentials (environment, shared profile, or an IAM role); set <code>AWS_*</code> / <code>AWS_REGION</code> in your shell or a <code>.env</code> before launching <code>serve</code> if you don't use a profile or role.</div>
      </div>
    </div>
    <div class="setsection" id="apikeysection" data-testid="settings.apikey-section">
      <div class="setlabel">Claude API key</div>
      <div class="keycur" id="keycur"></div>
      <label class="keylabel" for="apikey">New key</label>
      <div class="keyrow">
        <input type="password" id="apikey" data-testid="settings.apikey" class="keyinput" placeholder="sk-ant-…" autocomplete="off" spellcheck="false">
      </div>
      <div class="keyactions">
        <button class="keyclear" id="keyclear" data-testid="settings.key-clear">Clear</button>
      </div>
      <div class="fshint">Write-once: set or replace the key here; it is shown only masked and never displayed again. Used by the <b>Anthropic API</b> provider (Amazon Bedrock uses AWS credentials instead). Only the AI paths need it: <b>Record</b>, <b>Crawl</b>, and Replay with <code>--dismiss-alerts</code>.</div>
    </div>
    <div class="keyactions">
      <button class="cfgbtn keysave" id="settingssave" data-testid="settings.save">Save</button>
      <span class="keystatus" id="setstatus" data-testid="settings.status"></span>
    </div>
    <div class="fshint">Settings live in the running server's memory for this session only &mdash; <b>not written to disk</b>, so they reset when <code>serve</code> restarts. For values that survive restarts, set <code>ANTHROPIC_API_KEY</code> / <code>AWS_*</code> in your shell or a <code>.env</code> before launching <code>serve</code>.</div>
  </div>
</div>
<!-- ===== Screenshot lightbox: the enlarged screen + where it goes next (Crawl tab) ===== -->
<div class="modal" id="shotmodal" hidden>
  <div class="shotbox">
    <button class="fsclose shotclose" id="shotclose">&#10005;</button>
    <button class="shotnav prev" id="shotprev" title="previous screen — a transition into this one (←)">&#8249;</button>
    <div class="shotmain"><div class="shotframe"><img id="shotimg" alt="screen screenshot"><div class="shothots" id="shothots"></div><div class="shothi" id="shothi" hidden></div></div></div>
    <button class="shotnav fwd" id="shotfwd" title="next screen — a transition out of this one (→)">&#8250;</button>
    <div class="shotside">
      <div class="shottitle" id="shottitle"></div>
      <div class="shotnext" id="shotnext"></div>
    </div>
  </div>
</div>
<script>{{ js|safe }}</script>
</body></html>
