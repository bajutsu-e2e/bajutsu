<!DOCTYPE html>
{#- Self-contained coverage report (BE-0050). coverage.py builds the context; all markup lives
    here. CSS is inlined (no external asset, no JS) so the page works opened straight from disk. -#}
{%- macro bar(fraction) -%}
<div class="bar"><div class="fill" style="width: {{ (fraction * 100) | round(1) }}%"></div></div>
{%- endmacro -%}
{%- macro idlist(ids) -%}
{%- for id in ids %}<code>{{ id }}</code>{% if not loop.last %} {% endif %}{% endfor -%}
{%- endmacro -%}
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Coverage{% if target %} — {{ target }}{% endif %}</title>
<style>
:root { color-scheme: light dark; }
body { font: 15px/1.5 -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
  margin: 0; padding: 2rem; max-width: 880px; margin: 0 auto; color: #1d1d1f; background: #fff; }
h1 { font-size: 1.5rem; margin: 0 0 .25rem; }
h2 { font-size: 1.1rem; margin: 2rem 0 .75rem; border-bottom: 1px solid #e0e0e0; padding-bottom: .35rem; }
.sub { color: #6e6e73; margin: 0 0 1.5rem; }
section { margin-bottom: 1.5rem; }
.score { font-size: 1.05rem; font-weight: 600; margin: 0 0 .5rem; }
.bar { background: #e8e8ed; border-radius: 5px; height: 10px; overflow: hidden; margin: .25rem 0 1rem; }
.fill { background: #34c759; height: 100%; }
table { border-collapse: collapse; width: 100%; }
th, td { text-align: left; padding: .4rem .6rem; border-bottom: 1px solid #ececec; vertical-align: top; }
th { color: #6e6e73; font-weight: 600; font-size: .85rem; }
code { background: #f2f2f7; border-radius: 4px; padding: .1rem .35rem; font-size: .85em; }
.gap { color: #b00020; }
.empty { color: #6e6e73; font-style: italic; }
.tag { display: inline-block; background: #fde8e8; color: #b00020; border-radius: 4px;
  padding: .1rem .4rem; margin: 0 .3rem .3rem 0; font-size: .85em; }
.tag code { background: transparent; padding: 0; }
@media (prefers-color-scheme: dark) {
  body { color: #f5f5f7; background: #1c1c1e; }
  h2 { border-color: #3a3a3c; }
  .sub, th { color: #98989d; }
  .bar { background: #3a3a3c; }
  code { background: #2c2c2e; }
  th, td { border-color: #2c2c2e; }
  .gap { color: #ff6961; }
  .tag { background: #3a1f1f; color: #ff6961; }
}
</style>
</head>
<body>
<h1>E2E coverage{% if target %} — {{ target }}{% endif %}</h1>
<p class="sub">Read-only map of the surface this scenario suite exercises. No verdict — advisory only.</p>

<section>
<h2>Id namespaces (declared vs referenced)</h2>
<p class="score">{{ (static.coverage * 100) | round(1) }}% — {{ static.covered }}/{{ static.total }} namespaces referenced</p>
{{ bar(static.coverage) }}
{%- if static.namespaces %}
<table><thead><tr><th>namespace</th><th>referenced ids</th></tr></thead><tbody>
{%- for ns in static.namespaces %}
<tr><td><code>{{ ns.namespace }}</code></td><td>{{ idlist(ns.ids) }}</td></tr>
{%- endfor %}
</tbody></table>
{%- else %}
<p class="empty">No declared namespace is referenced by any scenario.</p>
{%- endif %}
{%- if static.gaps %}
<p class="gap"><strong>Gaps</strong> (declared, no scenario references): {% for ns in static.gaps %}<span class="tag"><code>{{ ns }}</code></span>{% endfor %}</p>
{%- endif %}
{%- if static.off_namespace %}
<p><strong>Off-namespace ids</strong> (referenced, namespace never declared): {{ idlist(static.off_namespace) }}</p>
{%- endif %}
</section>

{%- if endpoints is not none %}
<section>
<h2>Network endpoints (observed vs asserted)</h2>
<p class="score">{{ (endpoints.coverage * 100) | round(1) }}% — {{ endpoints.asserted | length }}/{{ endpoints.observed | length }} observed endpoints asserted</p>
{{ bar(endpoints.coverage) }}
{%- if endpoints.unasserted %}
<p class="gap"><strong>Unasserted</strong> (observed traffic no assertion covers): {{ idlist(endpoints.unasserted) }}</p>
{%- endif %}
{%- if endpoints.declared_unobserved %}
<p><strong>Declared but not observed</strong> (matchers that hit no exchange): {{ idlist(endpoints.declared_unobserved) }}</p>
{%- endif %}
{%- if not endpoints.observed %}
<p class="empty">No network traffic was observed across the run set.</p>
{%- endif %}
</section>
{%- endif %}

{%- if observed is not none %}
<section>
<h2>Observed ids (rendered vs declared namespaces)</h2>
<p class="score">{{ (observed.coverage * 100) | round(1) }}% — {{ observed.covered }}/{{ observed.total }} namespaces rendered in a run</p>
{{ bar(observed.coverage) }}
{%- if observed.namespaces %}
<table><thead><tr><th>namespace</th><th>observed ids</th></tr></thead><tbody>
{%- for ns in observed.namespaces %}
<tr><td><code>{{ ns.namespace }}</code></td><td>{{ idlist(ns.ids) }}</td></tr>
{%- endfor %}
</tbody></table>
{%- endif %}
{%- if observed.unobserved %}
<p class="gap"><strong>Unobserved</strong> (declared, rendered in no run): {% for ns in observed.unobserved %}<span class="tag"><code>{{ ns }}</code></span>{% endfor %}</p>
{%- endif %}
{%- if observed.off_namespace %}
<p><strong>Off-namespace ids</strong> (rendered, namespace never declared): {{ idlist(observed.off_namespace) }}</p>
{%- endif %}
</section>
{%- endif %}

{%- if screens is not none %}
<section>
<h2>Screens visited (crawl-discovered vs reached)</h2>
<p class="score">{{ (screens.coverage * 100) | round(1) }}% — {{ screens.covered }}/{{ screens.total }} discovered screens reached by a run</p>
{{ bar(screens.coverage) }}
{%- if screens.unvisited %}
<p class="gap"><strong>Unvisited</strong> (the crawl discovered them, no run reached them): {% for s in screens.unvisited %}<span class="tag"><code>{{ s.label }}</code></span>{% endfor %}</p>
{%- endif %}
{%- if not screens.total %}
<p class="empty">The crawl discovered no screens.</p>
{%- endif %}
</section>
{%- endif %}
</body>
</html>
