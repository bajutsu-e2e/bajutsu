# Copy to .env (gitignored) and fill in. Bajutsu loads .env at startup.
# Only the AI paths need this: `bajutsu record` and `bajutsu run --dismiss-alerts`.
# Real environment variables take precedence over this file.
ANTHROPIC_API_KEY=sk-ant-...

# Alternative to the API key, for the `claude-code` provider (ai.provider: claude-code).
# A headless host — CI, a container, a remote `serve` — can't run `claude setup-token`'s
# browser flow, so mint the long-lived token once on a machine that can and copy it in here.
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
