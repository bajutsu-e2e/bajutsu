{
  "rules": {
    "preset-ja-technical-writing": {
      "no-doubled-joshi": {
        "min_interval": 1,
        "strict": false,
        "allow": []
      },
      "ja-no-mixed-period": {
        "periodMark": "。",
        "allowPeriodMarks": ["}", "．"],
        "allowEmojiAtEnd": false,
        "forceAppendPeriod": false
      }
      "ja-no-redundant-expression": true,
      "no-mix-dearu-desumasu": true,
      "no-double-negative-ja": true,
      "ja-no-abusage": true,
      "no-dropping-the-ra": true,
      "no-doubled-conjunctive-particle-ga": true,
      "no-doubled-conjunction": true
    },
    "spellcheck-tech-word": true,
    "ja-hiragana-keishikimeishi": true,
    "ja-hiragana-fukushi": true,
    "ja-hiragana-hojodoushi": true,
    "general-novel-style-ja": {
      "chars_leading_paragraph": false,
      "no_punctuation_at_closing_quote": true,
      "space_after_marks": false,
      "even_number_ellipsises": false,
      "even_number_dashes": false,
      "appropriate_use_of_punctuation": true,
      "appropriate_use_of_interpunct": false,
      "appropriate_use_of_choonpu": false,
      "appropriate_use_of_minus_sign": false,
      "max_arabic_numeral_digits": false
    }
  }
}
