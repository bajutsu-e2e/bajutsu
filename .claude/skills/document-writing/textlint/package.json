{
  "name": "document-writing-textlint",
  "version": "0.0.0",
  "private": true,
  "description": "textlint runtime + ruleset shared by the document-writing, english-document-writing, and japanese-document-writing skills. Pins the tool so `npx --prefix <this dir> textlint` resolves the same versions everywhere.",
  "devDependencies": {
    "textlint": "15.7.1",
    "textlint-rule-preset-ja-technical-writing": "12.0.2",
    "textlint-rule-general-novel-style-ja": "1.3.0",
    "textlint-rule-ja-hiragana-fukushi": "1.3.0",
    "textlint-rule-ja-hiragana-hojodoushi": "1.1.0",
    "textlint-rule-ja-hiragana-keishikimeishi": "1.1.0",
    "textlint-rule-spellcheck-tech-word": "5.0.0",
    "textlint-rule-write-good": "2.0.0",
    "textlint-rule-stop-words": "5.2.0",
    "textlint-rule-unexpanded-acronym": "1.2.4",
    "textlint-rule-abbr-within-parentheses": "1.0.2",
    "textlint-rule-alex": "5.0.0",
    "textlint-rule-ukraine": "1.5.0",
    "textlint-rule-prefer-tari-tari": "1.0.3",
    "@textlint-ja/textlint-rule-no-insert-dropping-sa": "2.0.1",
    "textlint-rule-no-mixed-zenkaku-and-hankaku-alphabet": "1.0.1",
    "textlint-rule-joyo-kanji": "0.0.2",
    "textlint-rule-ja-joyo-or-jinmeiyo-kanji": "1.0.3",
    "textlint-rule-ja-kyoiku-kanji": "1.0.2",
    "textlint-rule-ja-allowed-kanji": "1.0.1",
    "textlint-rule-ja-hiraku": "1.4.0"
  },
  "overrides": {
    "@hono/node-server": "^2.0.5"
  }
}
