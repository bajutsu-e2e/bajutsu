# macOS
.DS_Store

# Local-only files (never committed)
UNCOMMITTED_CHANGES.md
tmp/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
build/
dist/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
coverage.json
htmlcov/
# Generated by the pip-audit CI job (uv export -> this file); never committed
pip-audit-requirements.txt

# Secrets (loaded by bajutsu at startup; .env.example is the tracked template)
.env

# Bajutsu run artifacts (evidence / reports)
runs/

# serve's ephemeral upload sandboxes (BE-0073): extracted bundles, cleared on serve start
uploads/

# Scenario generated by the offline record demo (demos/showcase/record/generate_from_nl.py)
demos/showcase/record/generated.yaml

# Scenario generated by the zero-setup tour (demos/tour/tour.py)
demos/tour/generated.yaml
# Working copy the on-device tour (demos/tour/demo.sh) edits in place
demos/tour/scenario.yaml

# iOS showcase suite (XcodeGen-generated projects + build output)
demos/showcase/*/*.xcodeproj/
demos/showcase/*/build/
BajutsuKit/Runner/*.xcodeproj/
.claude/launch.json
DerivedData/
*.xcuserstate

**/.build/**
**/.swiftpm/**

worktree
# Generated API reference output (BE-0065; `make docs`) — built, never committed.
site/
# Generated roadmap dashboard page (BE-XXXX; `make roadmap-dashboard`) — built from live BE
# metadata on every docs build, never committed (cannot drift, no CI-id-allocation coupling).
docs/api/roadmap.md

# serve upload temp dirs (BE-0073) — never commit extracted bundles
uploads/
