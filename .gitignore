# macOS
.DS_Store

# Local-only files (never committed)
UNCOMMITTED_CHANGES.md
tmp/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
build/
dist/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
.coverage.*
coverage.json
htmlcov/
# Generated by the pip-audit CI job (uv export -> this file); never committed
pip-audit-requirements.txt

# Secrets (loaded by bajutsu at startup; .env.example is the tracked template)
.env

# Bajutsu run artifacts (evidence / reports)
runs/
projects.json

# serve's persisted provider settings (LocalProviderSettingsStore) — runtime state, never committed
provider-settings.json

# serve's ephemeral upload sandboxes (BE-0073): extracted bundles, cleared on serve start
uploads/

# Scenario generated by the offline record demo (demos/showcase/record/generate_from_nl.py)
demos/showcase/record/generated.yaml

# Scenarios authored by the web record demo — the Web UI's Record tab auto-names into the target's
# configured scenarios dir (demos/web/record writes to gitignored tmp/ instead). The tracked web
# scenarios (smoke/counter/gestures) are named, so only the auto-named `generated*.yaml` are ignored.
demos/web/scenarios/generated*.yaml

# Scenario generated by the zero-setup tour (demos/tour/tour.py)
demos/tour/generated.yaml
# Working copy the on-device tour (demos/tour/demo.sh) edits in place
demos/tour/scenario.yaml

# iOS showcase suite (XcodeGen-generated projects + build output)
demos/showcase/ios/*/*.xcodeproj/
demos/showcase/ios/*/build/
# Codegen coverage output (BE-0297): the non-gating `ui-test-coverage` step regenerates these from
# proven scenarios on every run — generation-only, never committed (the required ComponentsUITests
# .swift is the only tracked generated UITest).
demos/showcase/ios/swiftui/UITests/Coverage*.swift
BajutsuKit/Runner/*.xcodeproj/
# Wheel-bundled generic XCUITest runner (BE-0292): built into the package by `make runner-bundle`
# at release time and force-included via pyproject `artifacts`; the compiled products are never
# committed (regenerated per Xcode/SDK), so ignore them here.
bajutsu/_xcuitest_runner/
.claude/launch.json
DerivedData/
*.xcuserstate

**/.build/**
**/.swiftpm/**

worktree
# Generated API reference output (BE-0065; `make docs`) — built, never committed.
site/
# Generated roadmap dashboard page (BE-XXXX; `make roadmap-dashboard`) — built from live BE
# metadata on every docs build, never committed (cannot drift, no CI-id-allocation coupling).
docs/api/roadmap.md

# serve upload temp dirs (BE-0073) — never commit extracted bundles
uploads/
demos/showcase/scenarios/baselines/
