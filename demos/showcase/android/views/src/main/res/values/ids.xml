<?xml version="1.0" encoding="utf-8"?>
<!-- The SPEC §5 identifier contract as android:id resources, one per element. An android:id name
     allows neither '.' nor '-', so the dotted SPEC ids map mechanically: both become '_'
     (stable.refresh → stable_refresh, search.results-empty → search_results_empty). View.aid(name)
     (Accessibility.kt) resolves these by name and assigns them in the a11y flavor only, where UI
     Automator surfaces them as `resource-id`. Data-derived rows are pre-declared over the fixture's
     fixed ranges (horses 1–5, notices 1–20; log rows over a bounded 1–10). -->
<resources>
    <!-- tab bar — the tab items themselves, one per idNamespace, no dot to map ('.'/'-') -->
    <item name="stable" type="id" />
    <item name="search" type="id" />
    <item name="log" type="id" />
    <item name="notice" type="id" />
    <item name="perm" type="id" />

