# Self-hosting bajutsu's single-tenant server backend (BE-0016 Tier B). Copy to `.env` and fill in.
# See docs/self-hosting.md ("Tier B — single-team self-hosting"). One team = one (default) org;
# multi-tenant isolation is not implemented yet.

# --- published-port bind address --------------------------------------------------------------
# Host interface the Redis/MinIO/serve ports bind to. Loopback by default. To let the native Mac
# worker reach Redis and MinIO, set this to the host's tailnet IP — never 0.0.0.0 on a host with a
# public interface.
BIND_ADDR=127.0.0.1

# --- request auth -----------------------------------------------------------------------------
# Shared operator token: required on every request (and to bind a non-loopback host). OAuth users
# below get a session instead; the token stays the operator/CI credential.
BAJUTSU_SERVE_TOKEN=change-me

# --- database (Postgres) ----------------------------------------------------------------------
POSTGRES_PASSWORD=change-me
# In this compose the DB URL is derived from POSTGRES_PASSWORD (see docker-compose.yml), so editing
# the password above is enough. The line below is only read outside compose; keep it in sync there.
BAJUTSU_DATABASE_URL=postgresql+psycopg://bajutsu:change-me@postgres:5432/bajutsu

# --- operator secret store (BE-0136) ----------------------------------------------------------
# Master key that encrypts operator secrets (the Claude API key set via the UI) at rest in the
# database. Required with a database wired — the server refuses to start without it. Generate one:
#   python3 -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# Losing it makes stored secrets unrecoverable; a rotated key can't decrypt values written before.
BAJUTSU_SECRETS_KEY=change-me

# --- queue / sessions (Redis) -----------------------------------------------------------------
BAJUTSU_REDIS_URL=redis://redis:6379
BAJUTSU_QUEUE=bajutsu
# Login-session lifetime in seconds (default 7 days).
BAJUTSU_SESSION_TTL=604800

# --- artifact + scenario storage (one URI selects the backend; BE-0204) -----------------------
# s3://bucket/prefix (S3-compatible, MinIO here) or gs://bucket/prefix (Google Cloud Storage).
BAJUTSU_SERVER_STORE=s3://bajutsu
BAJUTSU_S3_ENDPOINT=http://minio:9000
BAJUTSU_S3_REGION=auto
# AWS SDK credentials (also MinIO's root user/password in this compose).
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me

# --- GitHub OAuth login (optional; omit to run token-only) ------------------------------------
# Create a GitHub OAuth app; set the callback to https://<your-host>/api/oauth/callback.
BAJUTSU_OAUTH_GITHUB_CLIENT_ID=
BAJUTSU_OAUTH_GITHUB_CLIENT_SECRET=
BAJUTSU_OAUTH_GITHUB_REDIRECT_URI=
# Access follows GitHub organization and Team membership (BE-0313), not a login list: declare an
# `orgs:` block in your config (members / githubOrgs) to gate sign-in and grant the base viewer
# role, and its `editorTeam` to grant editor. Name the one server-wide admin Team here.
BAJUTSU_OAUTH_ADMIN_TEAM=

# --- quotas -----------------------------------------------------------------------------------
# Cap on one user's concurrent jobs (0 = unlimited).
BAJUTSU_MAX_CONCURRENT_PER_USER=0

# --- AI paths (optional; needed by `record` / `--dismiss-alerts`, on the WORKER's env) ---------
ANTHROPIC_API_KEY=

# --- public hostname (only when fronting with Caddy; tailnet-only deploys skip this) ----------
BAJUTSU_PUBLIC_HOST=

# --- metrics stack (only with the `metrics` profile: Prometheus + Grafana; BE-0169) -----------
# Grafana's initial admin password (user: admin). Prometheus scrapes /metrics with the operator
# token above, so no extra credential is needed there.
GRAFANA_ADMIN_PASSWORD=change-me
